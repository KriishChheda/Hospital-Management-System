generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id          String   @id @default(cuid())
  patientCode String   @unique          // Human-readable ID: "HMS-0001"
  createdAt   DateTime @default(now())

  // ── Personal Information ──
  name          String
  age           Int
  gender        String
  dateOfBirth   String   @default("")
  bloodGroup    String?
  maritalStatus String?
  nationality   String   @default("Indian")

  // ── Contact Information ──
  phone          String  @unique
  alternatePhone String?
  email          String?

  // ── Address ──
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String  @default("India")

  // ── Emergency Contact ──
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?

  // ── Identification ──
  aadhaarNumber String? @unique
  aadhaarDocUrl String?

  // ── Medical History (accumulates over time) ──
  allergies          String?
  existingConditions String[] // e.g. ["Diabetes", "Hypertension"]
  currentMedications String?
  pastSurgeries      String?
  disabilityInfo     String?

  // ── Consent ──
  detailsAccurate    Boolean @default(false)
  privacyAccepted    Boolean @default(false)

  // ── Visits (one patient → many visits) ──
  visits         Visit[]
}

// ── Visit: one record per clinic trip ──
model Visit {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])

  // ── Per-visit billing ──
  paymentStatus  Boolean  @default(false)
  registrationFee Float   @default(500.0)

  // ── Per-visit criticality ──
  critical       String   @default("low") // "high", "medium", "low"

  // ── Doctor assignment (set at registration) ──
  doctorProfileId String?               // which doctor this visit belongs to
  doctorProfile   DoctorProfile? @relation(fields: [doctorProfileId], references: [id])
  scheduledTime   DateTime?             // null = walk-in; DateTime = pre-booked slot

  // ── Relations scoped to this visit ──
  prescriptions  Prescription[]
  emrVisits      EMRVisit[]
  labOrders      LabOrder[]
  queueEntry     QueueEntry?            // back-relation (1:1, optional)
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
}

model User {
  id         String   @id @default(cuid())
  name       String
  employeeId String   @unique
  email      String   @unique
  password   String
  role       Role
  status     Boolean  @default(false) // false = Pending, true = Approved
  createdAt  DateTime @default(now())
}

model Medicine {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  name           String
  genericName    String?
  category       String   // e.g. "Antibiotic", "Analgesic"
  manufacturer   String?
  batchNumber    String?
  barcode        String?  @unique

  // Stock
  currentStock   Int      @default(0)
  minStockLevel  Int      @default(10)   // triggers low-stock alert
  unit           String   @default("tablets") // tablets, ml, capsules, etc.
  pricePerUnit   Float    @default(0)

  // Expiry
  expiryDate     DateTime?
  manufactureDate DateTime?

  // Relations
  prescriptionItems PrescriptionItem[]
  activityLogs      PharmacistLog[]
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
  CANCELLED
  PARTIAL
}

model Prescription {
  id          String             @id @default(cuid())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  visitId     String
  visit       Visit              @relation(fields: [visitId], references: [id])

  doctorId    String?            // links to User with role DOCTOR
  doctorName  String?            // denormalized for display speed

  notes       String?
  status      PrescriptionStatus @default(PENDING)

  items       PrescriptionItem[]
  logs        PharmacistLog[]
  billing     PharmacyBilling?
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])

  dosage         String       // e.g. "500mg"
  frequency      String       // e.g. "Twice daily"
  duration       String       // e.g. "7 days"
  quantity       Int          // units to dispense
  dispensed      Int          @default(0)
  instructions   String?
}

model PharmacistLog {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())

  pharmacistId   String    // User id
  pharmacistName String

  action         String    // "DISPENSED", "UPDATED_STOCK", "ADDED_MEDICINE", etc.
  details        String?

  prescriptionId String?
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  medicineId     String?
  medicine       Medicine?     @relation(fields: [medicineId], references: [id])
}

model PharmacyBilling {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  prescriptionId String   @unique
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  totalAmount    Float
  paid           Boolean  @default(false)
  paymentMethod  String?  // "Cash", "Card", "Insurance"
}

// ── EMR Medical Visit Tracking ──
model EMRVisit {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  visitId       String
  visit         Visit    @relation(fields: [visitId], references: [id])
  
  doctorId      String
  doctorName    String

  // Vital signs checked by nurse during triage
  bloodPressure String?
  temperature   String?
  heartRate     String?
  respiratoryRate String?
  weight        String?

  // Clinical Consultation Notes
  chiefComplaint String
  clinicalNotes  String   @db.Text
  diagnosis      String?
  aiSuggestions  String?  @db.Text // Cached AI Analysis output
  
  // Digital Printable Board Customizations
  customHeader   String?  @default("CITY GENERAL HOSPITAL - OUTPATIENT DEPARTMENT")
  customFooter   String?  @default("Please bring this prescription note on your next visit.")
}

// ── Laboratory Orders Dashboard Integration ──
enum LabOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model LabOrder {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  visitId       String
  visit         Visit          @relation(fields: [visitId], references: [id])
  
  doctorId      String
  doctorName    String
  
  testName      String         // e.g., "Complete Blood Count (CBC)", "X-Ray Chest"
  category      String         // e.g., "Blood", "Radiology", "Urinalysis"
  status        LabOrderStatus @default(PENDING)
  resultNotes   String?        @db.Text
  flaggedAlert  Boolean        @default(false) // Highlights critical abnormalities
}

// ── Doctor Profile & Availability ──
model DoctorProfile {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique          // links to User with role DOCTOR
  fullName        String
  specialization  String                    // e.g., "Cardiologist", "Radiologist"
  qualification   String?                   // e.g., "MBBS, MD"
  experience      Int?                      // years of experience
  phone           String?
  consultationFee Float?

  availableNow    Boolean  @default(false)  // live on/off toggle

  // Weekly time slots stored as JSON: { "monday": ["09:00-12:00","14:00-17:00"], ... }
  weeklySlots     Json     @default("{}")

  // ── Back-relations ──
  visits       Visit[]        // all visits assigned to this doctor
  queueEntries QueueEntry[]   // all active queue entries for this doctor
}

// ── Patient Queue ──
enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  DEFERRED
  CANCELLED
}

model QueueEntry {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())

  visitId          String      @unique
  visit            Visit       @relation(fields: [visitId], references: [id])

  doctorProfileId  String
  doctorProfile    DoctorProfile @relation(fields: [doctorProfileId], references: [id])

  checkInTime      DateTime    @default(now())  // when patient physically checked in
  status           QueueStatus @default(WAITING)

  // Receptionist manual control
  manualAdjustment Int         @default(0)  // positive = boost, negative = push back, 999 = urgent
  receptionistNote String?                  // optional reason for override

  // Computed & stored for display (recalculated on every GET)
  queueScore       Float       @default(0)
  position         Int?                     // 1-indexed rank in the doctor's queue
}