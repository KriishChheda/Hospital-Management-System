generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  age       Int
  gender    String
  phone     String   @unique
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
}

model User {
  id         String   @id @default(cuid())
  name       String
  employeeId String   @unique
  email      String   @unique
  password   String
  role       Role
  status     Boolean  @default(false) // false = Pending, true = Approved
  createdAt  DateTime @default(now())
}